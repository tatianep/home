---
import { publications } from "../data/profile";
---

<section id="publications" class="section">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="kicker"><b>03</b> — Publications</p>
      <h2>Selected papers</h2>
      <p class="lede">
        Peer-reviewed work spanning quantum devices, computational materials,
        and machine learning for physics. Click a row for the abstract.
      </p>
    </div>

    <ol class="papers">
      {publications.map((pub, i) => (
        <li data-reveal style={`--reveal-i: ${Math.min(i, 4)}`}>
          <details class="paper">
            <summary>
              <span class="year">{pub.year}</span>
              <span class="body">
                <span class="title">{pub.title}</span>
                <span class="venue">
                  {pub.venue}
                  {pub.note && <span class="note">{pub.note}</span>}
                </span>
              </span>
              <span class="toggle" aria-hidden="true">+</span>
            </summary>
            <div class="abstract">
              <p>{pub.abstract}</p>
              <a class="mlink" href={pub.url} target="_blank" rel="noopener">
                read the paper ↗
              </a>
            </div>
          </details>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .papers {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    border-top: 1px solid var(--line);
  }

  li:first-child {
    border-top: 0;
  }

  summary {
    display: grid;
    grid-template-columns: 5.5rem 1fr auto;
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: baseline;
    padding-block: 1.6rem;
    cursor: pointer;
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .year {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--text-3);
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.9vw, 1.3rem);
    font-weight: 420;
    color: var(--text);
    line-height: 1.35;
    text-wrap: pretty;
    background-image: var(--grad);
    background-repeat: no-repeat;
    background-size: 0% 1px;
    background-position: 0 100%;
    transition: background-size 0.35s ease;
  }

  .paper:hover .title,
  .paper[open] .title {
    background-size: 100% 1px;
  }

  .venue {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    color: var(--text-3);
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .note {
    color: var(--teal);
  }

  .toggle {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--text-3);
    transition: color 0.25s ease, rotate 0.3s ease;
  }

  .paper:hover .toggle {
    color: var(--teal);
  }

  .paper[open] .toggle {
    rotate: 45deg;
    color: var(--teal);
  }

  .abstract {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding-bottom: 1.7rem;
  }

  .abstract::before {
    content: "";
  }

  .abstract p {
    max-width: 64ch;
    font-size: 0.92rem;
    color: var(--text-2);
    margin: 0 0 0.9rem;
  }

  .abstract .mlink {
    grid-column: 2;
    justify-self: start;
  }

  /* Smooth open animation where supported */
  .paper::details-content {
    block-size: 0;
    overflow: clip;
    opacity: 0;
    transition:
      block-size 0.4s cubic-bezier(0.2, 0.55, 0.25, 1),
      content-visibility 0.4s allow-discrete,
      opacity 0.35s ease;
  }

  .paper[open]::details-content {
    block-size: auto;
    block-size: calc-size(auto, size);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .paper::details-content {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    summary {
      grid-template-columns: 1fr auto;
    }

    .year {
      grid-column: 1 / -1;
    }

    .abstract {
      grid-template-columns: 1fr;
    }

    .abstract::before {
      display: none;
    }
  }
</style>
