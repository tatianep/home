---
import { publications } from "../data/profile";
---

<section id="publications" class="section">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="kicker"><b>03</b> — Publications</p>
      <h2>Selected papers</h2>
      <p class="lede">
        Peer-reviewed work spanning quantum devices, computational materials,
        and machine learning for physics.
      </p>
    </div>

    <ol class="papers">
      {publications.map((pub, i) => (
        <li data-reveal style={`--reveal-i: ${Math.min(i, 4)}`}>
          <a class="paper" href={pub.url} target="_blank" rel="noopener">
            <span class="year">{pub.year}</span>
            <span class="body">
              <span class="title">{pub.title}</span>
              <span class="venue">
                {pub.venue}
                {pub.note && <span class="note">{pub.note}</span>}
              </span>
            </span>
            <span class="ext" aria-hidden="true">↗</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .papers {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .paper {
    display: grid;
    grid-template-columns: 5.5rem 1fr auto;
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: baseline;
    padding-block: 1.6rem;
    border-top: 1px solid var(--line);
    transition: background 0.25s ease;
  }

  li:first-child .paper {
    border-top: 0;
  }

  .year {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--text-3);
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.9vw, 1.3rem);
    font-weight: 420;
    color: var(--text);
    line-height: 1.35;
    text-wrap: pretty;
    background-image: var(--grad);
    background-repeat: no-repeat;
    background-size: 0% 1px;
    background-position: 0 100%;
    transition: background-size 0.35s ease;
  }

  .paper:hover .title {
    background-size: 100% 1px;
  }

  .venue {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    color: var(--text-3);
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .note {
    color: var(--teal);
  }

  .ext {
    color: var(--text-3);
    font-size: 0.9rem;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .paper:hover .ext {
    color: var(--teal);
    transform: translate(2px, -2px);
  }

  @media (max-width: 640px) {
    .paper {
      grid-template-columns: 1fr auto;
    }

    .year {
      grid-column: 1 / -1;
    }
  }
</style>
