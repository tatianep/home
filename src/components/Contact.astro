---
import { identity } from "../data/profile";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="contact" class="section contact">
  <div class="container">
    <p class="kicker" data-reveal><b>06</b> — Contact</p>
    <h2 data-reveal style="--reveal-i: 1">
      Let&rsquo;s build the future <em>together</em>.
    </h2>
    <p class="pitch" data-reveal style="--reveal-i: 2">
      Whether it&rsquo;s quantum hardware, machine learning, or the strange
      places they overlap — I&rsquo;m always glad to compare notes.
    </p>
    <p data-reveal style="--reveal-i: 3">
      <a class="email tlink" href={`mailto:${identity.email}`}>{identity.email}</a>
    </p>
    <div class="socials" data-reveal style="--reveal-i: 4">
      <a class="mlink" href={identity.social.github} target="_blank" rel="noopener">github</a>
      <a class="mlink" href={identity.social.linkedin} target="_blank" rel="noopener">linkedin</a>
      <a class="mlink" href={identity.social.x} target="_blank" rel="noopener">x</a>
      <a class="mlink" href={`${base}/resume.pdf`} target="_blank" rel="noopener">resume ↗</a>
    </div>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    padding-block: clamp(7rem, 16vh, 11rem);
  }

  .contact .kicker {
    margin-bottom: 1.4rem;
  }

  .contact h2 {
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    margin-bottom: 1.4rem;
  }

  .contact h2 em {
    font-style: italic;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .pitch {
    max-width: 46ch;
    margin-inline: auto;
    margin-bottom: 2.6rem;
  }

  .email {
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 2.4vw, 1.25rem);
    letter-spacing: 0.02em;
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2.8rem;
  }
</style>
