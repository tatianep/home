---
import { identity, trajectoryStrip } from "../data/profile";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="hero" aria-label="Introduction">
  <canvas id="wavefield" aria-hidden="true"></canvas>

  <div class="hero-inner container">
    <p class="kicker status">
      <span class="dot" aria-hidden="true"></span>
      {identity.company} — {identity.location}
    </p>

    <h1 class="name">
      Tatiane Santos<span class="suffix">, Ph.D.</span>
    </h1>

    <p class="role">{identity.role}</p>

    <p class="tagline">{identity.tagline}</p>

    <div class="actions">
      <a class="cta" href="#about">Read my story <span aria-hidden="true">↓</span></a>
      <a class="mlink" href={identity.social.github} target="_blank" rel="noopener">github</a>
      <a class="mlink" href={identity.social.linkedin} target="_blank" rel="noopener">linkedin</a>
      <a class="mlink" href={identity.social.x} target="_blank" rel="noopener">x</a>
    </div>
  </div>

  <div class="strip container" aria-label="Scientific trajectory">
    {trajectoryStrip.map((step, i) => (
      <>
        {i > 0 && <span class="arrow" aria-hidden="true">→</span>}
        <span class:list={["step", { current: i === trajectoryStrip.length - 1 }]}>{step}</span>
      </>
    ))}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: clip;
  }

  #wavefield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    mask-image: radial-gradient(120% 90% at 50% 42%, #000 35%, transparent 78%);
    -webkit-mask-image: radial-gradient(120% 90% at 50% 42%, #000 35%, transparent 78%);
  }

  .hero-inner {
    position: relative;
    width: 100%;
    padding-top: var(--nav-h);
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 1.6rem;
    color: var(--text-2);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--teal);
    box-shadow: 0 0 10px rgba(95, 212, 194, 0.8);
  }

  .name {
    font-size: clamp(3.2rem, 9.5vw, 6.8rem);
    font-weight: 390;
    letter-spacing: -0.022em;
    line-height: 1.02;
    margin-bottom: 1.2rem;
  }

  .suffix {
    font-style: italic;
    font-weight: 340;
    font-size: 0.42em;
    color: var(--text-3);
    letter-spacing: 0;
  }

  .role {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 380;
    font-size: clamp(1.25rem, 2.6vw, 1.7rem);
    margin: 0 0 1.4rem;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    width: fit-content;
  }

  .tagline {
    max-width: 46ch;
    font-size: clamp(1rem, 1.6vw, 1.13rem);
    color: var(--text-2);
    margin-bottom: 2.4rem;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 1.1rem 1.6rem;
    flex-wrap: wrap;
  }

  .cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--text);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.68rem 1.3rem;
    transition: border-color 0.25s ease, background 0.25s ease;
  }

  .cta:hover {
    border-color: var(--teal);
    background: rgba(95, 212, 194, 0.07);
  }

  .strip {
    position: absolute;
    bottom: 1.6rem;
    left: 0;
    right: 0;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--text-3);
  }

  .arrow {
    opacity: 0.5;
  }

  .step.current {
    color: var(--teal);
  }

  /* entrance sequence */
  @media (prefers-reduced-motion: no-preference) {
    .hero-inner > * {
      animation: hero-in 0.9s cubic-bezier(0.2, 0.55, 0.25, 1) both;
    }

    .status { animation-delay: 0.08s; }
    .name { animation-delay: 0.18s; }
    .role { animation-delay: 0.3s; }
    .tagline { animation-delay: 0.42s; }
    .actions { animation-delay: 0.54s; }

    .strip {
      animation: hero-in 0.9s cubic-bezier(0.2, 0.55, 0.25, 1) 0.75s both;
    }

    #wavefield {
      animation: wave-in 2.2s ease 0.3s both;
    }
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
  }

  @keyframes wave-in {
    from {
      opacity: 0;
    }
  }

  @media (max-width: 980px) {
    .strip {
      font-size: 0.62rem;
      gap: 0.5rem;
    }
  }

  @media (max-height: 640px), (max-width: 700px) {
    .strip {
      display: none;
    }
  }
</style>

<script>
  // ------------------------------------------------------------------
  // Wave-interference field. A grid of points lit by the superposition
  // of three traveling circular waves (plus one that follows the
  // pointer). Crests render teal, troughs violet — physically honest,
  // quietly animated. Static under prefers-reduced-motion.
  // ------------------------------------------------------------------
  const canvas = document.getElementById("wavefield") as HTMLCanvasElement | null;
  const hero = canvas?.parentElement;

  if (canvas && hero) {
    const ctx = canvas.getContext("2d")!;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const SPACING = 23;
    const sources = [
      { fx: 0.16, fy: 0.24, k: 0.030, speed: 1.05, amp: 1.0 },
      { fx: 0.85, fy: 0.16, k: 0.023, speed: -0.85, amp: 0.85 },
      { fx: 0.58, fy: 0.98, k: 0.017, speed: 0.7, amp: 0.75 },
    ];
    const AMP_TOTAL = sources.reduce((s, w) => s + w.amp, 0) * 0.82;

    interface Pt { x: number; y: number; d: number[] }
    let pts: Pt[] = [];
    let W = 0, H = 0;

    const pointer = { x: -1e4, y: -1e4, tx: -1e4, ty: -1e4, amp: 0, target: 0 };

    function resize() {
      const rect = hero!.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = Math.round(W * dpr);
      canvas!.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      pts = [];
      for (let y = SPACING / 2; y < H; y += SPACING) {
        for (let x = SPACING / 2; x < W; x += SPACING) {
          pts.push({
            x,
            y,
            d: sources.map((s) => Math.hypot(x - s.fx * W, y - s.fy * H)),
          });
        }
      }
    }

    function draw(t: number) {
      ctx.clearRect(0, 0, W, H);

      pointer.x += (pointer.tx - pointer.x) * 0.06;
      pointer.y += (pointer.ty - pointer.y) * 0.06;
      pointer.amp += (pointer.target - pointer.amp) * 0.03;

      for (const p of pts) {
        let v = 0;
        for (let i = 0; i < sources.length; i++) {
          const s = sources[i];
          v += s.amp * Math.sin(p.d[i] * s.k - t * s.speed);
        }
        if (pointer.amp > 0.01) {
          const dp = Math.hypot(p.x - pointer.x, p.y - pointer.y);
          v += pointer.amp * 0.9 * Math.sin(dp * 0.045 - t * 2.1) * Math.exp(-dp / 260);
        }

        const m = Math.max(-1, Math.min(1, v / AMP_TOTAL));
        const g = Math.pow(Math.abs(m), 1.45);
        const alpha = 0.05 + g * 0.6;
        const radius = 0.8 + g * 1.8;

        ctx.beginPath();
        ctx.arc(p.x, p.y, radius, 0, 6.2832);
        ctx.fillStyle =
          m > 0
            ? `rgba(124, 227, 207, ${alpha})`
            : `rgba(158, 152, 245, ${alpha})`;
        ctx.fill();
      }
    }

    resize();

    if (reduceMotion) {
      draw(2.4);
      new ResizeObserver(() => { resize(); draw(2.4); }).observe(hero);
    } else {
      let raf = 0;
      let last = performance.now();
      let t = 0;
      let running = false;

      const loop = (now: number) => {
        const dt = Math.min((now - last) / 1000, 0.05);
        last = now;
        t += dt * 0.85;
        draw(t);
        raf = requestAnimationFrame(loop);
      };

      const start = () => {
        if (!running) {
          running = true;
          last = performance.now();
          raf = requestAnimationFrame(loop);
        }
      };
      const stop = () => {
        running = false;
        cancelAnimationFrame(raf);
      };

      new ResizeObserver(resize).observe(hero);

      // Animate only while the hero is on screen and the tab is visible.
      new IntersectionObserver(
        ([e]) => (e.isIntersecting ? start() : stop()),
        { threshold: 0.02 }
      ).observe(canvas);

      document.addEventListener("visibilitychange", () =>
        document.hidden ? stop() : start()
      );

      hero.addEventListener("pointermove", (e: PointerEvent) => {
        const rect = canvas!.getBoundingClientRect();
        pointer.tx = e.clientX - rect.left;
        pointer.ty = e.clientY - rect.top;
        pointer.target = 1;
      });
      hero.addEventListener("pointerleave", () => {
        pointer.target = 0;
      });
    }
  }
</script>
