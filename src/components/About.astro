---
import { Image } from "astro:assets";
import portrait from "../assets/portrait.jpg";
import { about, identity } from "../data/profile";
---

<section id="about" class="section">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="kicker"><b>01</b> — About</p>
      <h2>Physics, data, and everything in&nbsp;between</h2>
    </div>

    <div class="grid">
      <div class="text" data-reveal style="--reveal-i: 1">
        <p class="lead">{about.lead}</p>
        {about.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <aside class="side" data-reveal style="--reveal-i: 2">
        <figure class="portrait">
          <Image
            src={portrait}
            alt="Portrait of Tatiane Santos"
            widths={[420, 640, 880]}
            sizes="(max-width: 820px) 90vw, 400px"
            loading="lazy"
          />
          <figcaption class="kicker">{identity.coordinates}</figcaption>
        </figure>

        <dl class="facts">
          {about.facts.map((f) => (
            <div class="fact">
              <dt class="kicker">{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .lead {
    font-family: var(--font-serif);
    font-weight: 380;
    font-size: clamp(1.3rem, 2.4vw, 1.65rem);
    line-height: 1.45;
    color: var(--text);
    margin-bottom: 1.6rem;
    letter-spacing: -0.005em;
  }

  .portrait {
    margin: 0 0 1.8rem;
  }

  .portrait :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 4.6;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid var(--line-strong);
    filter: saturate(0.92) contrast(1.02);
  }

  .portrait figcaption {
    margin-top: 0.8rem;
    letter-spacing: 0.14em;
  }

  .facts {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .fact {
    display: grid;
    grid-template-columns: 7.2rem 1fr;
    gap: 1rem;
    padding-block: 0.85rem;
    border-top: 1px solid var(--line);
    align-items: baseline;
  }

  .fact dd {
    margin: 0;
    color: var(--text);
    font-size: 0.92rem;
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .portrait :global(img) {
      max-width: 420px;
    }
  }
</style>
